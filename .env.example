# Copy the values you need from this file into your shell environment or a local
# untracked `.env` file before running the stack.
# Anything marked `# CHANGE` should be reviewed and updated for your setup.

# Shared MQTT broker settings
# CHANGE: replace with your MQTT broker host or IP
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
# CHANGE: fill these in if your broker requires authentication
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=0

# Central stack settings
MQTT_TOPIC=uwb/raw/+
CENTRAL_HISTORY_PATH=central_history.json
ANCHORS_PATH=anchors.json
VIS_HTTP_PORT=8000
# CHANGE: list the node IDs you actually deploy
UWB_NODES=rpi1,rpi2,rpi3,rpi4

# Node process settings
# CHANGE: each node needs its own unique ID
NODE_ID=rpi1
# CHANGE: match the serial device path on this Raspberry Pi
UWB_PORT=/dev/ttyACM0
UWB_BAUD=115200
MQTT_RAW_TOPIC_BASE=uwb/raw
MQTT_CMD_TOPIC_BASE=uwb/cmd

# UWB device defaults
# CHANGE: match the peer addresses configured on your hardware
UWB_PEER_ADDRS=1,2,3,4,5
UWB_FIRA_SLOT_RSTU=2400
UWB_FIRA_ROUND_SLOTS=14
# CHANGE: tune this if your firmware or timing setup needs a different ranging block duration
UWB_FIRA_BLOCK_MS=50

# Optional physical tuning
NODE_HEIGHT_DEFAULT_M=0.0
# CHANGE: update if your node heights differ from the anchor plane
NODE_HEIGHTS_M=rpi1:0.0,rpi2:0.0,rpi3:0.0,rpi4:0.0
