# The repo automatically loads this file before reading runtime config.
# Shell exports still win, so you can override any value with: export NAME=value
# Anything marked CHANGE should be reviewed and updated for your setup.

# Shared MQTT broker settings
# CHANGE: central usually uses 127.0.0.1; nodes should use the central machine LAN IP.
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=0

# Central stack settings
MQTT_TOPIC=uwb/raw/+
AUTOCAM_POSE_TOPIC_BASE=autocam/pose
CENTRAL_HISTORY_PATH=central_history.json
ANCHORS_PATH=anchors.json
VIS_HTTP_PORT=8000
CENTRAL_EVENT_LOG_PATH=central_pose_logger_output.txt
CENTRAL_LOGGER_CONSOLE=1
RAW_SERIAL_LOG_PATH=central_raw_input_log.txt
PIPELINE_DIAGNOSTIC_INTERVAL_S=10.0
SERIAL_DIAGNOSTIC_INTERVAL_S=10.0
HISTORY_FLUSH_INTERVAL_S=0.08
HISTORY_FLUSH_MAX_PENDING=1

# Central scheduler settings
# CHANGE: list the node IDs you actually deploy.
UWB_NODES=rpi1,rpi2,rpi3,rpi4
SLOT_TIMEOUT_S=6.0
INTER_SLOT_GAP_S=0.30
TIMEOUT_SKIP_THRESHOLD=2
TIMEOUT_COOLDOWN_S=5.0
TOKEN_RESPONSE_LIMIT=256
BURST_ACTIVE_S=0.50
BURST_RESPONSE_TIMEOUT_S=0.75
BURST_POST_PAUSE_GRACE_S=0.05

# Node process settings
# CHANGE: each node needs its own unique ID and serial device path.
NODE_ID=rpi1
OUTPUT_PREFIX=
UWB_PORT=/dev/ttyACM0
UWB_BAUD=115200
SERIAL_TIMEOUT_S=0.20
SERIAL_RECONNECT_DELAY_S=2.0
SERIAL_READY_DELAY_S=2.0
NODE_SLOT_INDEX=0
NODE_STAGGER_STEP_S=0.35
NODE_STAGGER_MAX_S=2.5
INIT_DELAY_S=0.0
MQTT_RAW_TOPIC_BASE=uwb/raw
MQTT_CMD_TOPIC_BASE=uwb/cmd
EVENT_LOG_PATH=rpi1_node_sender_log.txt
# On a node, change RAW_SERIAL_LOG_PATH to something like rpi1_raw_serial_output.txt.
# The central logger also uses RAW_SERIAL_LOG_PATH, so keep separate .env files per machine.

# UWB device defaults
# CHANGE: match the peer addresses and timing configured on your hardware.
UWB_PEER_ADDRS=1,2,3,4,5
UWB_INCLUDE_TIMING_ARGS=1
UWB_FIRA_SLOT_RSTU=2400
UWB_FIRA_ROUND_SLOTS=14
UWB_FIRA_BLOCK_MS=50
UWB_INIT_COMMAND=
UWB_PAUSE_AFTER_INIT=1
UWB_ACTIVATE_COMMANDS=
UWB_ACTIVATE_COMMAND_DELAY_S=0.05
UWB_PAUSE_COMMANDS=
UWB_PAUSE_COMMAND_DELAY_S=0.05
UWB_PRE_INIT_COMMANDS=
UWB_PRE_INIT_COMMAND_DELAY_S=0.20
UWB_SHUTDOWN_COMMANDS=
UWB_SHUTDOWN_COMMAND_DELAY_S=0.10
MEASUREMENT_TIMEOUT_S=4.5
POST_INIT_SETTLE_S=0.20
MEASUREMENT_EARLY_ACCEPT_SUCCESS_COUNT=3
CONTINUOUS_TIMEOUT_REINIT_THRESHOLD=1

# Optional physical tuning
NODE_HEIGHT_DEFAULT_M=0.0
# CHANGE: update if your node heights differ from the anchor plane.
NODE_HEIGHTS_M=rpi1:0.0,rpi2:0.0,rpi3:0.0,rpi4:0.0

# Dynamic homography motor controller
# Safe default: dry-run only. Set to 1 only after validating directions at low speed.
MOTOR_ENABLE_LIVE=0
MOTOR_DEBUG=0
MOTOR_LOG_INTERVAL_S=1.0
MOTOR_MODBUS_PORT=/dev/ttyUSB0
MOTOR_MODBUS_BAUD=9600
MOTOR_MODBUS_TIMEOUT_S=1.0
PAN_ENABLED=1
TRUCK_ENABLED=1
MOTOR_CONFIRM_RECENTERED=0
MOTOR_ARM_PROMPT=0
AUTOCAM_TARGET_SELECT_TOPIC=autocam/target/select
AUTOCAM_VISION_CORRECTION_TOPIC=autocam/vision/correction
AUTOCAM_MOTOR_ARM_TOPIC=autocam/motor/arm
AUTOCAM_TARGET_NODE=rpi1

# Camera profile/intrinsics. Presets are fallback only; calibrated values override them.
CAMERA_PROFILE=iphone_13_pro_max_main_1x
CAMERA_IMAGE_W=1920
CAMERA_IMAGE_H=1080
CAMERA_FX=1450.0
CAMERA_FY=1450.0
CAMERA_CX=960.0
CAMERA_CY=540.0
CAMERA_K1=0.0
CAMERA_K2=0.0
CAMERA_P1=0.0
CAMERA_P2=0.0
CAMERA_K3=0.0

# World placement of the rail in the UWB coordinate system.
# Positive rail motion advances from this origin along CAMERA_RAIL_HEADING_DEG.
CAMERA_RAIL_ORIGIN_X_M=0.0
CAMERA_RAIL_ORIGIN_Y_M=0.0
CAMERA_RAIL_HEADING_DEG=0.0

# Manually recenter pan/truck to this estimated startup pose before arming.
# CAMERA_START_RAIL_M is the camera's local position along the rail, not world x.
CAMERA_START_RAIL_M=0.0
CAMERA_START_PAN_DEG=0.0
CAMERA_HEIGHT_M=1.4
CAMERA_PITCH_DEG=35.0
CAMERA_ROLL_DEG=0.0

# Legacy fallback fields from the original x-axis-only model. Leave blank unless you
# need backward compatibility with old configs; the rail fields above are preferred.
CAMERA_START_X_M=
CAMERA_START_Y_M=

# Motor identity, signs, calibration, and soft limits.
PAN_MOTOR_ID=1
TRUCK_MOTOR_ID=2
PAN_DRIVER_MODEL=BLD510B
TRUCK_DRIVER_MODEL=BLD305S
PAN_POLE_PAIRS=2
TRUCK_POLE_PAIRS=5
PAN_SIGN=1
TRUCK_SIGN=1
PAN_DEG_PER_RAW_SPEED_S=0.01
TRUCK_M_PER_RAW_SPEED_S=0.00005
PAN_MIN_DEG=-70.0
PAN_MAX_DEG=70.0
TRUCK_MIN_RAIL_M=-1.0
TRUCK_MAX_RAIL_M=1.0

# Legacy fallback rail-limit aliases from the original x-axis-only model.
TRUCK_MIN_X_M=
TRUCK_MAX_X_M=

# Hierarchical pan/truck control defaults.
MOTOR_TARGET_STALE_S=0.75
MOTOR_MIN_QUALITY=0.55
MOTOR_RAMP_RAW_PER_S=35
PAN_RAMP_RAW_PER_S=35
TRUCK_RAMP_RAW_PER_S=35
PAN_MAX_RAW_SPEED=35
TRUCK_MAX_RAW_SPEED=60
PAN_IMAGE_DEADBAND_PX=150
TRUCK_IMAGE_DEADBAND_PX=80
PAN_PREALIGN_THRESHOLD_PX=160
PAN_CENTERED_THRESHOLD_PX=60
TRUCK_ENABLE_AFTER_PAN_CENTERED_MS=500
PAN_CONTROL_HZ=20
PAN_KP_RAW_PER_PX=0.25
TRUCK_KP_RAW_PER_PX=0.08
PAN_ERROR_FILTER_ALPHA=0.08
PAN_ERROR_FILTER_TAU_S=0.35
PAN_DIRECTION_FLIP_HOLD_MS=350
PAN_CENTER_HOLD_MS=250
TRUCK_ERROR_FILTER_ALPHA=0.05
TRUCK_ERROR_FILTER_TAU_S=0.15
PAN_PREFERRED_YAW_MIN_DEG=-25.0
PAN_PREFERRED_YAW_MAX_DEG=25.0
MOTOR_SAFE_IMAGE_MARGIN_PX=120
MOTOR_TARGET_IMAGE_X_PX=
MOTOR_TARGET_IMAGE_Y_PX=

# Future CV image-space correction seam. Disabled for v1 by default.
VISION_CORRECTION_STALE_S=0.25
VISION_CORRECTION_MIN_CONFIDENCE=0.60
VISION_CORRECTION_BLEND=0.0
# Manual motor jogging and limit discovery
# Use with: python -m motor_controller --manual --axis truck
MOTOR_MANUAL_JOG_RAW_SPEED=8
MOTOR_MANUAL_JOG_DURATION_S=0.10
MOTOR_MANUAL_MAX_RAW_SPEED=20
MOTOR_MANUAL_MAX_DURATION_S=0.30
MOTOR_MANUAL_SETTLE_S=0.20
MOTOR_MANUAL_STATUS_POLL_S=0.02
MOTOR_MANUAL_PRINT_POLL_SAMPLES=0
MOTOR_MANUAL_TRUCK_M_PER_RAW_SPEED_S=0.00005
MOTOR_MANUAL_PAN_DEG_PER_RAW_SPEED_S=0.01
MOTOR_MANUAL_GOTO_MAX_DURATION_S=0.10
MOTOR_MANUAL_GOTO_TOLERANCE=0.002
MOTOR_MANUAL_PAN_GOTO_TOLERANCE=5.0
MOTOR_MANUAL_TRUCK_GOTO_TOLERANCE=0.002
MOTOR_MANUAL_GOTO_MAX_STEPS=50
MOTOR_MANUAL_GOTO_SPEED_FACTOR=1.5
MOTOR_MANUAL_GOTO_MIN_RAW_SPEED=2
MOTOR_MANUAL_GOTO_MAX_RAW_SPEED=20
MOTOR_MANUAL_LIMIT_MARGIN_M=0.05
MOTOR_MANUAL_CONFIRM_LIMIT_OVERRIDE=1
